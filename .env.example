# ── MLBuilder Environment Variables ──
# Copy to .env.local and fill in values

# Site URL — used for canonical URLs, sitemap, OG images
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Search Console verification code (optional)
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification code (optional)
BING_SITE_VERIFICATION=

# Database — PostgreSQL connection string (Docker default below)
DATABASE_URL="postgresql://mlbuilder:mlbuilder_dev_password@localhost:5432/mlbuilder?schema=public"

# NextAuth Configuration
# Generate a secret via command line: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Resend — Email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=MLBuilder <hello@mlbuilder.in>
