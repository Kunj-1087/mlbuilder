# ── MLBuilder Environment Variables ──
# Copy to .env.local and fill in values

# Site URL — used for canonical URLs, sitemap, OG images
VITE_SITE_URL=https://mlbuilder.in

# PostHog Analytics
# Get from https://posthog.com/ → create project → Settings → API Keys
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Note: EU region (https://eu.i.posthog.com) preferred for Indian/global users

# Google Search Console verification code (optional)
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification code (optional)
BING_SITE_VERIFICATION=

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mlbuilder

# Resend — Email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=MLBuilder <hello@mlbuilder.in>
