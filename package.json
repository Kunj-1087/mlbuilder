{
  "name": "mlbuilder-nextjs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose stop postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "dev:all": "concurrently -n DB,APP -c blue,green \"npm run db:start && docker compose logs -f postgres\" \"npm run dev\"",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:db:start": "docker compose -f docker-compose.test.yml up -d",
    "test:db:reset": "npx tsx tests/helpers/seed.ts",
    "test:db:stop": "docker compose -f docker-compose.test.yml down"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "2.1.1",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "next": "^15.1.0",
    "next-auth": "5.0.0-beta.25",
    "next-mdx-remote": "^6.0.0",
    "posthog-js": "^1.395.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.16.0",
    "shiki": "^4.3.0",
    "tailwind-merge": "3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "4.1.17",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "concurrently": "^9.1.0",
    "happy-dom": "^15.0.0",
    "msw": "^2.6.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "4.1.17",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "^2.1.0"
  }
}
